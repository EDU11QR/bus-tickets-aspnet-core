@{
    ViewData["Title"] = "Editar Horario";
    Layout = "~/Views/Shared/_LayoutMaster.cshtml";
}

<h3 class="mb-4">📊 Dashboard</h3>

<div class="row text-center">

    <div class="col-md-2"><div class="card p-3 shadow">@ViewBag.TotalRutas<br />Rutas</div></div>
    <div class="col-md-2"><div class="card p-3 shadow">@ViewBag.TotalBuses<br />Buses</div></div>
    <div class="col-md-2"><div class="card p-3 shadow">@ViewBag.TotalHorarios<br />Horarios</div></div>
    <div class="col-md-2"><div class="card p-3 shadow">@ViewBag.TotalReservas<br />Reservas</div></div>
    <div class="col-md-2"><div class="card p-3 shadow">S/. @ViewBag.TotalIngresos<br />Ingresos</div></div>

</div>

<div class="row mt-5">

    <div class="col-md-6">
        <h5>Reservas por día</h5>
        <canvas id="graficoReservas"></canvas>
    </div>

    <div class="col-md-6">
        <h5>Ingresos por mes</h5>
        <canvas id="graficoIngresos"></canvas>
    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    new Chart(document.getElementById('graficoReservas'), {
        type: 'line',
        data: {
            labels: @Html.Raw(Json.Serialize(ViewBag.Fechas)),
            datasets: [{
                label: 'Reservas',
                data: @Html.Raw(Json.Serialize(ViewBag.Reservas))
            }]
        }
    });

    new Chart(document.getElementById('graficoIngresos'), {
        type: 'bar',
        data: {
            labels: @Html.Raw(Json.Serialize(ViewBag.Meses)),
            datasets: [{
                label: 'Ingresos',
                data: @Html.Raw(Json.Serialize(ViewBag.Ingresos))
            }]
        }
    });
</script>