@{
    Layout = null; // 🔥 pantalla limpia tipo login real
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Login - BusTicket</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Poppins', sans-serif;
            background: linear-gradient(135deg, #0f172a, #1e293b);
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .login-card {
            width: 380px;
            background: #ffffff;
            border-radius: 16px;
            padding: 30px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.25);
            animation: fadeIn 0.5s ease;
        }

        .login-title {
            font-weight: 600;
            text-align: center;
            margin-bottom: 20px;
            color: #1e293b;
        }

        .form-control {
            border-radius: 10px;
            padding: 10px;
        }

        .btn-login {
            width: 100%;
            border-radius: 10px;
            padding: 10px;
            background: linear-gradient(135deg, #22c55e, #16a34a);
            border: none;
            font-weight: 600;
        }

            .btn-login:hover {
                background: linear-gradient(135deg, #16a34a, #15803d);
            }

        .error-text {
            text-align: center;
            margin-top: 10px;
            color: red;
            font-size: 14px;
        }

        .logo {
            text-align: center;
            font-size: 28px;
            margin-bottom: 10px;
        }

            .logo span {
                color: #22c55e;
                font-weight: bold;
            }

        @@keyframes fadeIn { {
            from {
                opacity: 0;
                transform: translateY(10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
</head>

<body>

    <div class="login-card">

        <div class="logo">
            🚌 <span>BusTicket</span>
        </div>

        <h4 class="login-title">Iniciar Sesión</h4>

        <form method="post">

            <div class="mb-3">
                <label>Correo</label>
                <input name="correo" class="form-control" placeholder="ejemplo@gmail.com" required />
            </div>

            <div class="mb-3">
                <label>Clave</label>
                <input name="clave" type="password" class="form-control" placeholder="••••••••" required />
            </div>

            <button class="btn btn-login">Ingresar</button>

            @if (ViewBag.Error != null)
            {
                <div class="error-text">
                    @ViewBag.Error
                </div>
            }

        </form>

    </div>

</body>
</html>