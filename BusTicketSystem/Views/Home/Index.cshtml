@{
    ViewData["Title"] = "Inicio";
    Layout = "~/Views/Shared/_LayoutMaster.cshtml";
}

<!-- ================= HERO ================= -->
<div class="hero d-flex align-items-center justify-content-center text-center text-white">
    <div>
        <h1 class="fw-bold">BusTicket System</h1>
        <p class="lead">Gestión inteligente de rutas, horarios y reservas</p>
        <a href="/Rutas" class="btn btn-success btn-lg mt-2">🚀 Ver Rutas</a>
    </div>
</div>

<!-- ================= ACCIONES ================= -->
<div class="container mt-5">
    <div class="row text-center g-3">

        <div class="col-md-3">
            <a href="/Rutas" class="card p-4 shadow h-100">
                <h4>🚍</h4>
                <h5>Rutas</h5>
                <p>Gestionar rutas</p>
            </a>
        </div>

        <div class="col-md-3">
            <a href="/Horarios" class="card p-4 shadow h-100">
                <h4>⏱</h4>
                <h5>Horarios</h5>
                <p>Ver horarios</p>
            </a>
        </div>

        <div class="col-md-3">
            <a href="/Buses" class="card p-4 shadow h-100">
                <h4>🚌</h4>
                <h5>Buses</h5>
                <p>Administrar buses</p>
            </a>
        </div>

        <div class="col-md-3">
            <a href="/Reservas" class="card p-4 shadow h-100">
                <h4>🎫</h4>
                <h5>Reservas</h5>
                <p>Control de ventas</p>
            </a>
        </div>

    </div>
</div>

<!-- ================= STATS ================= -->
<div class="container mt-5">
    <div class="row text-center g-3">

        <div class="col-md-4">
            <div class="card p-4 shadow stat-card">
                <h2 class="counter">@ViewBag.TotalRutas</h2>
                <p>Rutas registradas</p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card p-4 shadow stat-card">
                <h2 class="counter">@ViewBag.TotalBuses</h2>
                <p>Buses activos</p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card p-4 shadow stat-card">
                <h2 class="counter">@ViewBag.TotalHorarios</h2>
                <p>Horarios disponibles</p>
            </div>
        </div>

    </div>
</div>

<!-- ================= GRAFICO ================= -->
<div class="container mt-5">
    <h4 class="text-center mb-3">📊 Estadísticas</h4>
    <canvas id="graficoHome" style="max-height:300px;"></canvas>
</div>

<!-- ================= GALERIA ================= -->
<div class="container mt-5">
    <h3 class="text-center mb-4">Experiencia de viaje</h3>

    <div class="row g-3">
        <div class="col-md-4">
            <img src="/img/bus1.jpg" class="img-card shadow" />
        </div>
        <div class="col-md-4">
            <img src="/img/bus2.jpg" class="img-card shadow" />
        </div>
        <div class="col-md-4">
            <img src="/img/bus3.jpg" class="img-card shadow" />
        </div>
    </div>
</div>

<!-- ================= BENEFICIOS ================= -->
<div class="container mt-5">
    <div class="row text-center">

        <div class="col-md-4">
            <h5>🚍 Viajes seguros</h5>
            <p>Control total de rutas y unidades</p>
        </div>

        <div class="col-md-4">
            <h5>⏱ Puntualidad</h5>
            <p>Gestión precisa de horarios</p>
        </div>

        <div class="col-md-4">
            <h5>💳 Reservas rápidas</h5>
            <p>Optimiza ventas y control</p>
        </div>

    </div>
</div>

<!-- ================= CTA FINAL ================= -->
<div class="text-center mt-5 mb-5">
    <h4>¿Listo para gestionar tu sistema?</h4>
    <a href="/Rutas" class="btn btn-primary btn-lg mt-2">
        🚀 Empezar ahora
    </a>
</div>

<!-- ================= SCRIPTS ================= -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    new Chart(document.getElementById('graficoHome'), {
        type: 'doughnut',
        data: {
            labels: ['Rutas', 'Buses', 'Horarios'],
            datasets: [{
                data: [
    @ViewBag.TotalRutas,
    @ViewBag.TotalBuses,
    @ViewBag.TotalHorarios
                    ]
            }]
        }
    });

    // 🔥 animación contador
    document.querySelectorAll('.counter').forEach(el => {
        let target = +el.innerText;
        let count = 0;

        let interval = setInterval(() => {
            count += Math.ceil(target / 30);
            if (count >= target) {
                el.innerText = target;
                clearInterval(interval);
            } else {
                el.innerText = count;
            }
        }, 30);
    });
</script>