<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BusTicketSystem</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true" />
</head>
<body>
    <div class="wrapper">

        <!-- SIDEBAR -->
        <aside class="sidebar">
            <h2 class="logo">🚌 BusTicket</h2>

            <nav>
                <a asp-controller="Home" asp-action="Index">🏠 Inicio</a>
                <a asp-controller="Buses" asp-action="Index">🚌 Buses</a>
                <a asp-controller="Rutas" asp-action="Index">🗺️ Rutas</a>
                <a asp-controller="Horarios" asp-action="Index">⏰ Horarios</a>
                <a asp-controller="Reservas" asp-action="Index">🎫 Reservas</a>
                <a asp-controller="Reportes" asp-action="Index">📊 Reportes</a>
            </nav>
        </aside>

        <!-- MAIN -->
        <div class="main-content">

            <!-- TOPBAR -->
            <header class="topbar d-flex justify-content-between align-items-center">
                <h5 class="m-0">@ViewData["Title"]</h5>
                <span class="user">👤 Admin</span>
            </header>

            <!-- CONTENT -->
            <main class="content">
                @RenderBody()
            </main>

            <!-- FOOTER -->
            <footer class="footer">
                © @DateTime.Now.Year - BusTicketSystem
            </footer>

        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>