<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BusTicketSystem</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        body {
            margin: 0;
            padding: 0;
            background-color: #f4f6f9;
            font-family: Arial, sans-serif;
        }

        .wrapper {
            display: flex;
            min-height: 100vh;
        }

        .sidebar {
            width: 250px;
            background-color: #212529;
            color: white;
            padding: 20px 15px;
        }

        .sidebar h2 {
            font-size: 22px;
            margin-bottom: 30px;
            text-align: center;
        }

        .sidebar a {
            display: block;
            color: #ddd;
            text-decoration: none;
            padding: 10px 15px;
            border-radius: 6px;
            margin-bottom: 10px;
            transition: 0.3s;
        }

        .sidebar a:hover {
            background-color: #0d6efd;
            color: white;
        }

        .main-content {
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        .topbar {
            background-color: white;
            padding: 15px 25px;
            border-bottom: 1px solid #ddd;
        }

        .content {
            padding: 25px;
        }

        .footer {
            margin-top: auto;
            background-color: white;
            text-align: center;
            padding: 15px;
            border-top: 1px solid #ddd;
            font-size: 14px;
            color: #666;
        }
    </style>
</head>
<body>
    <div class="wrapper">
        <aside class="sidebar">
            <h2>BusTicketSystem</h2>

            <a asp-controller="Home" asp-action="Index">Inicio</a>
            <a asp-controller="Buses" asp-action="Index">Buses</a>
            <a asp-controller="Rutas" asp-action="Index">Rutas</a>
            <a asp-controller="Horarios" asp-action="Index">Horarios</a>
            <a asp-controller="Reservas" asp-action="Index">Reservas</a>
            <a asp-controller="Reportes" asp-action="Index">Reportes</a>
        </aside>

        <div class="main-content">
            <header class="topbar">
                <h4 class="m-0">@ViewData["Title"]</h4>
            </header>

            <main class="content">
                @RenderBody()
            </main>

            <footer class="footer">
                © @DateTime.Now.Year - BusTicketSystem
            </footer>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>