@model BusTicketSystem.Models.Ruta

<h3>Editar Ruta</h3>
<div class="alert alert-warning d-flex align-items-center">
    <span style="font-size:20px; margin-right:10px;">⚠️</span>
    <div>
        <strong>Importante:</strong><br />
        Los horarios ya registrados no cambiarán automáticamente al modificar la duración de la ruta.
    </div>
</div>
<form asp-action="Editar" method="post">

    <input type="hidden" asp-for="IdRuta" />

    <div class="form-group">
        <label>Origen</label>
        <input asp-for="Origen" class="form-control" />
    </div>

    <div class="form-group">
        <label>Destino</label>
        <input asp-for="Destino" class="form-control" />
    </div>

    <div class="form-group">
        <label>Duración</label>
        <input asp-for="DuracionEstimada" class="form-control" />
    </div>

    <div class="form-group">
        <label>Precio Base</label>
        <input asp-for="PrecioBase" type="number" step="0.01" class="form-control" />
    </div>

    <div class="form-group">
        <label>Estado</label>
        <select asp-for="Estado" class="form-control">
            <option value="true">Activo</option>
            <option value="false">Inactivo</option>
        </select>
    </div>

    <br />

    <button type="submit" class="btn btn-primary">Actualizar</button>
</form>