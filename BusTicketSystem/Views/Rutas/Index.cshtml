@model List<BusTicketSystem.Models.Ruta>

@{
    ViewData["Title"] = "Rutas";
    Layout = "~/Views/Shared/_LayoutMaster.cshtml";
}

<div class="card-custom">

    <div class="d-flex justify-content-between mb-3">
        <h3>Lista de Rutas</h3>
        <a asp-action="Crear" class="btn btn-success">+ Nueva Ruta</a>
    </div>

    <table class="table table-hover">
        <thead>
            <tr>
                <th>Origen</th>
                <th>Destino</th>
                <th>Duración</th>
                <th>Precio Base</th>
                <th>Estado</th>
                <th style="width:150px;">Acciones</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var r in Model)
            {
                <tr>
                    <td>@r.Origen</td>
                    <td>@r.Destino</td>
                    <td>
                        @($"{r.DuracionEstimada.Hours}h" +
                                            (r.DuracionEstimada.Minutes > 0 ? $" {r.DuracionEstimada.Minutes}min" : ""))
                </td>
                    <td><strong>S/. @r.PrecioBase</strong></td>

                    <td>
                        @if (r.Estado)
                        {
                            <span class="badge bg-success">Activo</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Inactivo</span>
                        }
                    </td>

                    <td>
                        <a asp-action="Editar" asp-route-id="@r.IdRuta"
                           class="btn btn-warning btn-sm">✏️</a>

                        <a asp-action="Eliminar" asp-route-id="@r.IdRuta"
                           class="btn btn-danger btn-sm"
                           onclick="return confirm('¿Eliminar esta ruta?');">
                            🗑️
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

</div>